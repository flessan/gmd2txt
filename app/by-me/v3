<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Super GMD Extractor</title>
    <style>
        :root {
            --sky: #87CEEB;
            --sky-light: #E0F7FA;
            --y: #FFE135;      /* Kuning Goofy */
            --g: #9ACD32;      /* Hijau Goofy */
            --b: #5D4037;      /* Coklat Border */
            --text: #3E2723;
            --red: #FF6B6B;
            --shadow: 4px 4px 0 var(--b);
        }

        * { box-sizing: border-box; }

        body {
            background: linear-gradient(180deg, var(--sky) 0%, #B3E5FC 100%);
            color: var(--text);
            font-family: 'Comic Sans MS', 'Chalkboard SE', sans-serif;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: flex-start; /* Agar bisa scroll */
        }

        /* Container Utama */
        .app-card {
            background: #FFFDE7;
            width: 100%;
            max-width: 550px;
            border-radius: 30px;
            border: 6px solid var(--b);
            box-shadow: 10px 10px 0 var(--b);
            padding: 25px;
            position: relative;
            overflow: hidden;
        }

        h2 {
            margin: 0 0 10px;
            text-align: center;
            color: var(--b);
            text-shadow: 2px 2px 0 var(--y);
            font-size: 28px;
        }

        .subtitle {
            text-align: center; 
            font-size: 14px; 
            margin-bottom: 20px;
            color: #6D4C41;
        }

        /* Drop Zone */
        .drop-zone {
            border: 4px dashed var(--b);
            border-radius: 20px;
            padding: 40px 20px;
            text-align: center;
            background: rgba(255,255,255,0.5);
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
        }

        .drop-zone:hover, .drop-zone.drag-over {
            background: var(--y);
            border-style: solid;
            transform: scale(1.02);
        }

        .drop-zone-icon { font-size: 40px; display: block; margin-bottom: 10px; }
        .drop-zone input { display: none; }

        /* File List */
        .file-list {
            margin-top: 20px;
            max-height: 300px;
            overflow-y: auto;
            border-top: 4px solid var(--b);
            padding-top: 15px;
        }

        .file-item {
            background: white;
            border: 3px solid var(--b);
            border-radius: 15px;
            padding: 10px 15px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
            box-shadow: var(--shadow);
            animation: popIn 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }

        @keyframes popIn { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }

        .file-icon { font-size: 20px; }
        .file-info { flex-grow: 1; text-align: left; overflow: hidden; }
        .file-name { font-weight: bold; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .file-status { font-size: 12px; color: #888; font-weight: normal; }
        
        .file-actions { display: flex; gap: 5px; }
        
        /* Buttons */
        .btn {
            border: 2px solid var(--b);
            border-radius: 8px;
            padding: 6px 10px;
            font-family: inherit;
            font-weight: bold;
            cursor: pointer;
            font-size: 12px;
            transition: 0.1s;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

        .btn-primary { background: var(--y); color: var(--b); box-shadow: 2px 2px 0 var(--b); }
        .btn-primary:hover { background: var(--g); transform: translate(1px, 1px); box-shadow: 1px 1px 0 var(--b); }
        
        .btn-secondary { background: #E0F7FA; color: var(--b); }
        .btn-secondary:hover { background: #B2EBF2; }

        .btn-danger { background: var(--red); color: white; border-color: #C62828; }
        
        /* Main Convert Button */
        .convert-btn-main {
            width: 100%;
            padding: 15px;
            margin-top: 20px;
            font-size: 18px;
            border-radius: 50px;
            background: var(--y);
            border: 4px solid var(--b);
            box-shadow: var(--shadow);
            cursor: pointer;
            font-family: inherit;
            font-weight: bold;
            transition: 0.2s;
        }

        .convert-btn-main:hover {
            background: var(--g);
            transform: translate(2px, 2px);
            box-shadow: 2px 2px 0 var(--b);
        }

        .convert-btn-main:disabled {
            background: #ccc;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        /* Modal Preview */
        .modal-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(30, 30, 30, 0.7);
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 100;
            backdrop-filter: blur(2px);
        }

        .modal-content {
            background: #FFFDE7;
            border: 6px solid var(--b);
            border-radius: 20px;
            width: 90%;
            max-width: 500px;
            max-height: 80vh;
            display: flex;
            flex-direction: column;
            box-shadow: 10px 10px 0 var(--b);
            animation: popIn 0.3s;
        }

        .modal-header {
            padding: 15px;
            border-bottom: 4px solid var(--b);
            font-weight: bold;
            text-align: center;
            background: var(--sky-light);
            border-radius: 14px 14px 0 0;
        }

        .modal-body {
            padding: 15px;
            flex-grow: 1;
            overflow-y: auto;
        }

        .preview-text {
            width: 100%;
            height: 200px;
            border: 3px solid var(--b);
            border-radius: 10px;
            background: white;
            padding: 10px;
            font-size: 12px;
            resize: none;
            font-family: monospace;
        }

        .modal-footer {
            padding: 15px;
            border-top: 4px solid var(--b);
            display: flex;
            gap: 10px;
            justify-content: center;
        }

        /* Utility */
        .hidden { display: none !important; }
        .text-success { color: var(--g) !important; font-weight: bold; }
        .text-error { color: var(--red) !important; font-weight: bold; }
        
        /* Loading Spinner */
        .spinner {
            display: inline-block;
            width: 16px;
            height: 16px;
            border: 3px solid rgba(0,0,0,0.1);
            border-radius: 50%;
            border-top-color: var(--b);
            animation: spin 1s ease-in-out infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

    </style>
</head>
<body>

    <div class="app-card">
        <h2>GMD2TXT Extractor</h2>
        <div class="subtitle">Drag, Drop, Convert, and Go!</div>

        <!-- Drop Zone -->
        <div class="drop-zone" id="dropZone">
            <label for="fileInput">
                <span class="drop-zone-icon">&#9729;</span>
                <span style="font-weight: bold; display: block;">Drop .GMD files here!</span>
                <span style="font-size: 12px; color: #666;">or click to browse</span>
            </label>
            <input type="file" id="fileInput" accept=".gmd" multiple>
        </div>

        <!-- File List -->
        <div id="fileListContainer" class="hidden">
            <div class="file-list" id="fileList"></div>
            
            <button class="convert-btn-main" id="processAllBtn">
                Convert All Files
            </button>
        </div>

        <!-- Hidden Status -->
        <div id="status" style="text-align: center; margin-top: 10px; font-size: 14px;"></div>
    </div>

    <!-- Modal Preview -->
    <div class="modal-overlay" id="previewModal">
        <div class="modal-content">
            <div class="modal-header" id="modalTitle">Preview</div>
            <div class="modal-body">
                <textarea class="preview-text" id="previewContent" readonly></textarea>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" onclick="closeModal()">Close</button>
                <button class="btn btn-primary" id="copyBtn" onclick="copyText()">Copy Text</button>
                <button class="btn btn-primary" id="downloadSingleBtn">Download</button>
            </div>
        </div>
    </div>

    <script>
        const dropZone = document.getElementById('dropZone');
        const fileInput = document.getElementById('fileInput');
        const fileList = document.getElementById('fileList');
        const fileListContainer = document.getElementById('fileListContainer');
        const processAllBtn = document.getElementById('processAllBtn');
        const previewModal = document.getElementById('previewModal');
        const previewContent = document.getElementById('previewContent');
        const modalTitle = document.getElementById('modalTitle');
        const copyBtn = document.getElementById('copyBtn');
        const downloadSingleBtn = document.getElementById('downloadSingleBtn');
        const statusDiv = document.getElementById('status');

        let filesQueue = [];
        let currentPreviewData = null;

        // --- Interaction Logic ---

        // Drag & Drop Events
        ['dragenter', 'dragover', 'dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, preventDefaults, false);
        });

        function preventDefaults(e) {
            e.preventDefault();
            e.stopPropagation();
        }

        ['dragenter', 'dragover'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => dropZone.classList.add('drag-over'), false);
        });

        ['dragleave', 'drop'].forEach(eventName => {
            dropZone.addEventListener(eventName, () => dropZone.classList.remove('drag-over'), false);
        });

        dropZone.addEventListener('drop', handleDrop, false);
        fileInput.addEventListener('change', (e) => handleFiles(e.target.files), false);
        dropZone.addEventListener('click', () => fileInput.click());

        function handleDrop(e) {
            const dt = e.dataTransfer;
            const files = dt.files;
            handleFiles(files);
        }

        function handleFiles(files) {
            filesQueue = [...files]; // Add to queue
            renderFileList();
        }

        // --- UI Rendering ---

        function renderFileList() {
            if (filesQueue.length === 0) {
                fileListContainer.classList.add('hidden');
                return;
            }

            fileListContainer.classList.remove('hidden');
            fileList.innerHTML = '';

            filesQueue.forEach((file, index) => {
                const div = document.createElement('div');
                div.className = 'file-item';
                div.id = `file-item-${index}`;
                
                div.innerHTML = `
                    <div class="file-icon">&#128196;</div>
                    <div class="file-info">
                        <div class="file-name">${file.name}</div>
                        <div class="file-status" id="status-${index}">Ready to convert</div>
                    </div>
                    <div class="file-actions">
                        <button class="btn btn-secondary" onclick="removeFile(${index})" title="Remove">&#10006;</button>
                    </div>
                `;
                fileList.appendChild(div);
            });
        }

        function removeFile(index) {
            filesQueue.splice(index, 1);
            renderFileList();
        }

        // --- Core Processing Logic ---

        processAllBtn.addEventListener('click', () => {
            if (filesQueue.length === 0) return;
            
            // Visual feedback
            processAllBtn.disabled = true;
            processAllBtn.innerHTML = '<span class="spinner"></span> Processing...';
            statusDiv.textContent = '';

            let successCount = 0;
            let errorCount = 0;

            // Use Promise.all to wait for all files to process
            const promises = filesQueue.map((file, index) => {
                return processFile(file, index).then(res => {
                    if (res.success) successCount++;
                    else errorCount++;
                });
            });

            Promise.all(promises).then(() => {
                processAllBtn.disabled = false;
                processAllBtn.innerHTML = 'Convert All Files';
                
                if (errorCount === 0) {
                    statusDiv.innerHTML = `<span class="text-success">All done! ${successCount} files converted.</span>`;
                } else {
                    statusDiv.innerHTML = `<span class="text-error">Finished with ${errorCount} errors.</span>`;
                }
                
                // Clear queue after processing? Optional. Let's keep the list so user can preview.
                // filesQueue = []; 
            });
        });

        function processFile(file, index) {
            return new Promise((resolve) => {
                const reader = new FileReader();
                const statusEl = document.getElementById(`status-${index}`);

                statusEl.innerHTML = '<span class="spinner"></span> Reading...';
                statusEl.className = "file-status";

                reader.onload = function(event) {
                    const content = event.target.result;
                    const regex = /<k>k4<\/k>\s*<s>(.*?)<\/s>/s;
                    const match = content.match(regex);

                    if (match && match[1]) {
                        const extractedText = match[1];
                        const blob = new Blob([extractedText], { type: 'text/plain' });
                        const url = URL.createObjectURL(blob);
                        
                        // Success UI
                        statusEl.textContent = 'Success!';
                        statusEl.classList.add('text-success');
                        
                        // Trigger Download immediately
                        triggerDownload(url, file.name.replace(/\.gmd$/i, '.txt'));

                        // Add Preview/Download buttons to the card
                        const actionsDiv = document.querySelector(`#file-item-${index} .file-actions`);
                        const previewBtn = document.createElement('button');
                        previewBtn.className = 'btn btn-primary';
                        previewBtn.innerHTML = '&#128065;'; // Eye icon
                        previewBtn.title = "Preview";
                        previewBtn.onclick = () => openPreview(file.name, extractedText, url);
                        
                        // Prepend buttons (before remove button)
                        actionsDiv.prepend(previewBtn);

                        resolve({ success: true });
                    } else {
                        statusEl.textContent = 'Error: No data found';
                        statusEl.classList.add('text-error');
                        resolve({ success: false });
                    }
                };

                reader.onerror = function() {
                    statusEl.textContent = 'Read Error';
                    statusEl.classList.add('text-error');
                    resolve({ success: false });
                };

                reader.readAsText(file);
            });
        }

        function triggerDownload(url, filename) {
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
        }

        // --- Modal / Preview Functions ---

        function openPreview(name, text, blobUrl) {
            currentPreviewData = { text, blobUrl, name: name.replace('.txt', '.gmd') };
            modalTitle.textContent = name;
            previewContent.value = text;
            downloadSingleBtn.onclick = () => triggerDownload(blobUrl, name);
            previewModal.style.display = 'flex';
        }

        function closeModal() {
            previewModal.style.display = 'none';
            currentPreviewData = null;
        }

        function copyText() {
            if (!currentPreviewData) return;
            navigator.clipboard.writeText(currentPreviewData.text).then(() => {
                const origText = copyBtn.innerText;
                copyBtn.innerText = 'Copied!';
                copyBtn.style.background = 'var(--g)';
                setTimeout(() => {
                    copyBtn.innerText = origText;
                    copyBtn.style.background = '';
                }, 1500);
            });
        }

        // Close modal if clicked outside
        previewModal.addEventListener('click', (e) => {
            if (e.target === previewModal) closeModal();
        });

    </script>
</body>
</html>
